# 项目路径通常不需要配置，程序会自动以项目根目录为基准。

# FastAPI 服务配置
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8800
FASTAPI_BASE_URL=http://127.0.0.1:8800


# 大模型与 Embedding 配置
DEFAULT_LLM_PROVIDER=qwen
API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEFAULT_CHAT_MODEL=qwen-plus
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEFAULT_EMBEDDING_MODEL=text-embedding-v3
DEFAULT_EMBEDDING_BATCH_SIZE=10

# RAG 默认参数
DEFAULT_PARSER=pypdf
DEFAULT_SPLITTER=recursive
DEFAULT_CHUNK_SIZE=700
DEFAULT_CHUNK_OVERLAP=80
DEFAULT_VECTOR_TOP_K=10
DEFAULT_BM25_TOP_K=10
DEFAULT_FINAL_TOP_K=5

# MinerU 解析配置；不使用 MinerU 时可以留空 token。
MINERU_API_BASE_URL=https://mineru.net
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm
MINERU_LANGUAGE=ch
MINERU_IS_OCR=false
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_FORMULA=true
MINERU_PAGE_RANGES=
MINERU_POLL_INTERVAL=10
MINERU_TIMEOUT=1800
MINERU_DOWNLOAD_RETRY=3
MINERU_DOWNLOAD_TIMEOUT=300
MINERU_DOWNLOAD_VERIFY_SSL=true

# 功能开关
# 长期记忆 SQLite 双写
MEMORY_SQLITE_DUAL_WRITE=true   # 设为 true 开启 SQLite 双写和调试 API（默认开启）

# SQLite 主读（阶段 3 — 验证中，默认关闭）
# true → recall_context() 优先从 SQLite 读取 session/case/ticket 维度，失败时回退 JSON
# false → 保持 JSON 主读路径（默认，推荐）
MEMORY_READ_FROM_SQLITE=false

# Session TTL 配置（天数）
# 注：expired / archived 均为状态标记，不是物理删除。当前阶段不执行物理删除。
#   - active 且 updated_at < now - EXPIRE 天 → expired
#   - expired 且 updated_at < now - ARCHIVE 天 → archived
#   - CLEANUP 是预留清理窗口配置，本阶段不执行删除
MEMORY_SESSION_EXPIRE_AFTER_DAYS=7    # active → expired 天数
MEMORY_SESSION_ARCHIVE_AFTER_DAYS=14  # expired → archived 天数
MEMORY_SESSION_CLEANUP_AFTER_DAYS=7   # archived 后清理窗口（预留配置，本阶段不执行删除）

